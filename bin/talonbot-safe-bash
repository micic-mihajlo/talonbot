#!/usr/bin/env bash
set -euo pipefail

if [ "$#" -eq 0 ]; then
  echo "usage: talonbot-safe-bash <command>"
  exit 1
fi

COMMAND="$*"

block() {
  echo "blocked: $1"
  exit 64
}

if echo "$COMMAND" | grep -E -qi '(^|[[:space:]])rm[[:space:]]+-rf[[:space:]]+/( |$)'; then
  block "dangerous recursive deletion"
fi

if echo "$COMMAND" | grep -E -qi '(docker[[:space:]]+run|docker[[:space:]]+create).*(--privileged|--pid=host|--network=host)'; then
  block "unsafe docker privilege flags"
fi

if echo "$COMMAND" | grep -E -qi '(docker[[:space:]]+run|docker[[:space:]]+create).*(-v|--volume)[[:space:]]+/:/'; then
  block "unsafe docker host root mount"
fi

if echo "$COMMAND" | grep -E -qi '(^|[[:space:]])(chmod|chown)[[:space:]].*/(etc|root|proc)'; then
  block "system permission modification"
fi

if echo "$COMMAND" | grep -E -qi '(^|[[:space:]])(>|>>)[[:space:]]*/(etc|root|proc)/'; then
  block "writing to privileged paths"
fi

if echo "$COMMAND" | grep -E -qi 'curl[[:space:]].*\|[[:space:]]*(bash|sh)'; then
  block "remote script execution pipeline"
fi

if echo "$COMMAND" | grep -E -qi '/proc/(self|[0-9]+)/(environ|cmdline)'; then
  block "runtime process secret exfiltration path"
fi

if echo "$COMMAND" | grep -E -qi '(sudo[[:space:]]+su|su[[:space:]]+-|sudo[[:space:]]+-i)'; then
  block "privilege escalation shell"
fi

exec bash -lc "$COMMAND"
